theme = Dimidium
font-family = SF Mono
font-family = D2Coding
font-size = 12
adjust-cell-height = 11
adjust-cursor-height = 11
cursor-style-blink = false
shell-integration-features = no-cursor
cursor-style = block
font-thicken = true
macos-window-shadow = false
clipboard-trim-trailing-spaces = true
desktop-notifications = true
macos-option-as-alt = right

# Pane splitting (prefix: ctrl+x)
split-divider-color = "gray"
unfocused-split-opacity = 0.6
keybind = ctrl+x>shift+backslash=new_split:right
keybind = ctrl+x>minus=new_split:down

# Pane navigation
keybind = ctrl+x>h=goto_split:left
keybind = ctrl+x>j=goto_split:bottom
keybind = ctrl+x>k=goto_split:top
keybind = ctrl+x>l=goto_split:right

# Pane resize
keybind = ctrl+x>ctrl+h=resize_split:left,50
keybind = ctrl+x>ctrl+j=resize_split:down,50
keybind = ctrl+x>ctrl+k=resize_split:up,50
keybind = ctrl+x>ctrl+l=resize_split:right,50

# Pane zoom / close
keybind = ctrl+x>m=toggle_split_zoom
keybind = ctrl+x>x=close_surface

# Equalize splits
keybind = ctrl+x>equal=equalize_splits

# Workspace (tab) management
keybind = ctrl+x>c=new_tab
keybind = ctrl+x>p=previous_tab
keybind = ctrl+x>n=next_tab